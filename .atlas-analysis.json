  "keyFeatures": [
    "Interactive init wizard that configures multiple AI agent environments in one step",
    "Phase-based development workflow (requirements, design, planning, implementation, testing, deployment, monitoring)",
    "Agent Skill management with registry support — install, remove, search, and update skills",
    "Persistent knowledge memory service with scoped store and full-text search",
    "Agent control plane — list running agents, send messages, inspect conversation history",
    "Workspace lint validation to ensure AI-readiness of your project",
    "Declarative install via .ai-devkit.json config file for CI/team onboarding",
    "Global command setup to make AI DevKit commands available across all projects"
  ],
  "publicApiSurface": [
    "ai-devkit init",
    "ai-devkit phase [name]",
    "ai-devkit skill add <registry-repo> [skill-name]",
    "ai-devkit skill list",
    "ai-devkit skill remove <skill-name>",
    "ai-devkit skill update [registry-id]",
    "ai-devkit skill find <keyword>",
    "ai-devkit skill rebuild-index",
    "ai-devkit memory store",
    "ai-devkit memory search",
    "ai-devkit memory update",
    "ai-devkit agent list",
    "ai-devkit agent open <name>",
    "ai-devkit agent send <message>",
    "ai-devkit agent detail",
    "ai-devkit lint",
    "ai-devkit install",
    "ai-devkit setup"
  ]
